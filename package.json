{
  "name": "fivenine-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --filter @fivenine-collective/ui build && pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint:packages": "publint library && attw --pack library --profile esm-only --entrypoints . dropdown",
    "size": "pnpm --filter @fivenine-collective/ui run size",
    "build:docs": "pnpm --filter @fivenine-collective/ui build && pnpm --filter @fivenine-collective/docs build",
    "build:site": "node scripts/build-site.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm --filter @fivenine-collective/ui build && pnpm lint:packages && changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@changesets/cli": "^2.29.0",
    "publint": "^0.3.0"
  }
}
