{
  "name": "fivenine-ui",
  "version": "0.0.0",
  "description": "A CSS-first UI component library with optional JavaScript behaviors.",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/js/index.d.ts",
      "default": "./dist/js/index.js"
    },
    "./css": "./dist/css/fivenine-ui.css",
    "./css/*": "./dist/css/*",
    "./cdn/*": "./dist/cdn/*",
    "./*": {
      "types": "./dist/js/*.d.ts",
      "default": "./dist/js/*.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "./dist/cdn/fivenine-ui.iife.js",
  "jsdelivr": "./dist/cdn/fivenine-ui.iife.js",
  "scripts": {
    "build": "tsdown && node scripts/build-barrel.mjs && node scripts/build-css.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "lightningcss": "^1.30.1",
    "tsdown": "^0.15.6",
    "typescript": "^5.7.0"
  }
}
