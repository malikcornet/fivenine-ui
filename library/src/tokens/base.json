{
  "font": {
    "sans": { "$value": "ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, sans-serif" },
    "mono": { "$value": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace" }
  },
  "space": {
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" }
  },
  "radius": {
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" }
  },
  "transition": {
    "fast": { "$value": "120ms ease" }
  }
}
