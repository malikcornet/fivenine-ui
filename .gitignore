node_modules/
dist/
dist-site/
*.log

# npm pack tarballs (publint/attw pack the package; interrupted runs can leave these)
*.tgz

# Vite leaves these behind if a dev server dies mid-restart
vite.config.*.timestamp-*

# Environment files (none used today — safety net so secrets never land in git)
.env
.env.*
!.env.example

# Claude Code personal settings (launch.json is shared and stays tracked)
.claude/settings.local.json

# Token CSS generated by library/build-tokens.mjs from library/src/tokens/
library/tokens/

# Flattened+minified everything bundle generated by the @fivenine-collective/ui build
library/all.min.css

# Astro
docs/.astro/

.DS_Store
