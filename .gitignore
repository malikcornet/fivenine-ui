node_modules/
dist/
dist-site/
.turbo/
*.log

# npm pack tarballs (publint/attw pack the packages; interrupted runs can leave these)
*.tgz

# Vite leaves these behind if a dev server dies mid-restart
vite.config.*.timestamp-*

# TypeScript incremental build state
*.tsbuildinfo

# Environment files (none used today — safety net so secrets never land in git)
.env
.env.*
!.env.example

# Claude Code personal settings (launch.json is shared and stays tracked)
.claude/settings.local.json

# .NET
bin/
obj/
*.user
targets/blazor/publish/
nupkgs/

# Core assets synced into the Blazor RCL (generated by scripts/sync-blazor-assets.mjs)
targets/blazor/FiveNine.UI/wwwroot/fivenine/

# Token CSS generated by library/build-tokens.mjs from library/src/tokens/
library/tokens/

# Flattened+minified everything bundle generated by the @fivenine/ui build
library/all.min.css

# Astro
docs/.astro/

.DS_Store
