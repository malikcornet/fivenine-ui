---
import '@fivenine-collective/ui/all.css';
import '../docs.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// Set by scripts/build-site.mjs when building a released version from its tag;
// the latest build (site root) leaves it unset.
const docsVersion = process.env.DOCS_VERSION ?? 'latest';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script is:inline>
      // Apply the persisted theme before first paint to avoid a flash.
      (function () {
        var stored = localStorage.getItem('fn-docs-theme');
        var theme =
          stored === 'dark' || stored === 'light'
            ? stored
            : matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="fn-app" data-base={base} data-docs-version={docsVersion}>
    <header class="docs-header">
      <a href={base} class="docs-brand">fivenine<span>/ui</span></a>
      <div class="docs-header__controls">
        <select class="docs-select" data-version-select aria-label="Version" hidden></select>
        <button
          type="button"
          class="fn-btn fn-btn--secondary docs-theme-toggle"
          data-theme-toggle
          aria-label="Toggle theme"
        >
        </button>
      </div>
    </header>
    <main class="docs-main">
      <slot />
    </main>
    <script>
      import '../scripts/docs.ts';
    </script>
  </body>
</html>
